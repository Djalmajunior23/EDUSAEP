rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Safety Net (Pillar 0)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthenticated() {
      return isSignedIn();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
        (
          request.auth.token.email == "djalmabatistajunior@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           (getUserData().get('role', '') in ['ADMIN', 'admin']))
        );
    }

    function isTeacher() {
      return isSignedIn() && (
        request.auth.token.email == "djalmabatistajunior@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         getUserData().get('role', '') in ['TEACHER', 'professor', 'COORDINATOR', 'COORDENADOR', 'ADMIN', 'admin'])
      );
    }

    function isProfessor() {
      return isTeacher();
    }

    function isAluno() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (getUserData().get('role', '') in ['STUDENT', 'aluno', 'MONITOR', 'monitor']);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidQuestion(data) {
      // Validating the new SAEPQuestion structure
      return hasRequiredFields(['enunciado', 'alternativas', 'respostaCorreta', 'dificuldade']) &&
             isValidString('enunciado', 1, 5000) &&
             data.alternativas is list &&
             data.alternativas.size() >= 2 &&
             data.alternativas.size() <= 10 &&
             data.respostaCorreta is string &&
             data.dificuldade in ['fácil', 'médio', 'difícil'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isTeacher();
      allow create: if isOwner(userId) && 
        (request.resource.data.role in ['TEACHER', 'STUDENT'] || request.auth.token.email == "djalmabatistajunior@gmail.com");
      allow update: if isAdmin() || (isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role));
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || isProfessor()) && isValidQuestion(request.resource.data);
      allow update: if (isAdmin() || isProfessor()) && isValidQuestion(request.resource.data);
      allow delete: if isAdmin() || isProfessor();
    }

    match /simulados/{simuladoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /resultados/{resultadoId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || isProfessor();
      allow create: if isOwner(request.resource.data.studentId);
      allow update: if isAdmin() || (isAluno() && isOwner(resource.data.studentId));
      allow delete: if isAdmin();
    }

    match /desempenho/{desempenhoId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || isProfessor();
      allow write: if isAdmin() || isProfessor();
    }

    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
      allow write: if isAdmin() || isProfessor() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /diagnostics/{diagnosticId} {
      allow get: if isSignedIn() && (isTeacher() || resource.data.studentId == request.auth.uid || resource.data.userId == request.auth.uid || resource.data.studentEmail == request.auth.token.email);
      allow list: if isSignedIn() && (isTeacher() || resource.data.studentId == request.auth.uid || resource.data.userId == request.auth.uid || resource.data.studentEmail == request.auth.token.email);
      allow write: if isTeacher();
    }

    match /cognitiveLoadChecks/{checkId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher() || resource.data.studentId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /pedagogicalDecisions/{decisionId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher() || resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || isTeacher();
    }

    match /mass_rescue_actions/{actionId} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin() || isTeacher();
    }

    match /lesson_plans/{planId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher());
      allow write: if isAdmin() || isTeacher();
    }

    match /recovery_plans/{planId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher() || resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || isTeacher();
    }

    match /system_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /ai_usage_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /adaptive_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }

    match /student_exams/{studentExamId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /simulado_forms/{formId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /exam_submissions/{submissionId} {
      function isValidSubmission(data) {
        return data.studentId == request.auth.uid &&
               data.answers is list &&
               data.score is number &&
               data.maxScore is number;
      }
      allow get: if isSignedIn() && (isTeacher() || isOwner(existing().studentId));
      allow list: if isSignedIn() && (isTeacher() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && isValidSubmission(request.resource.data);
      allow update: if (isTeacher() || isOwner(existing().studentId)) && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['professorFeedback', 'professorNota', 'updatedAt', 'notified']);
      allow delete: if isAdmin();
    }

    match /study_plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor() || (isAuthenticated() && (request.auth.uid == request.resource.data.userId || request.auth.uid == resource.data.userId));
    }

    match /recomendacoes_pedagogicas/{recommendationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Allowed for students generating their own
      allow update: if isAdmin() || isProfessor();
      allow delete: if isAdmin();
    }

    match /content_recommendations/{recId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    match /learning_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor() || (isAuthenticated() && (request.auth.uid == request.resource.data.userId || request.auth.uid == resource.data.userId));
    }

    match /pedagogical_recommendations/{recId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    match /cognitive_error_analyses/{analysisId} {
      allow read: if isAuthenticated() && (isAdmin() || isTeacher() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    match /performance_predictions/{predictionId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    match /educational_missions/{missionId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isProfessor() || (isAuthenticated() && request.auth.uid == resource.data.userId); 
    }

    match /smart_goals/{goalId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.userId == request.auth.uid);
      allow write: if isAuthenticated() && (isAdmin() || isProfessor() || request.auth.uid == request.resource.data.userId);
    }

    match /career_matches/{matchId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    match /learning_dna/{dnaId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    match /engagement_logs/{logId} {
      allow read: if isAdmin() || isProfessor();
      allow create: if isAuthenticated();
    }
    
    match /classes/{classId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor());
      allow write: if isAdmin() || isProfessor();
    }
    
    match /disciplines/{disciplineId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /learning_situations/{saId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /sa_submissions/{submissionId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || isProfessor();
      allow create: if isAluno() && isOwner(request.resource.data.studentId);
      allow update: if (isAdmin() || isProfessor()) || (isAluno() && isOwner(resource.data.studentId));
      allow delete: if isAdmin();
    }

    match /student_chat_messages/{messageId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin();
      allow create: if isAluno() && isOwner(request.resource.data.studentId);
      allow update, delete: if isAdmin();
    }

    match /import_batches/{batchId} {
      allow read: if isAdmin() || isProfessor();
      allow write: if isAdmin() || isProfessor();
    }

    match /teacher_generated_contents/{contentId} {
      allow read: if isOwner(resource.data.createdBy) || isAdmin();
      allow create: if isAdmin() || isProfessor();
      allow update, delete: if isOwner(resource.data.createdBy) || isAdmin();
    }

    match /teacher_monthly_limits/{limitId} {
      allow read, write: if isAuthenticated() && (limitId.startsWith(request.auth.uid) || isAdmin());
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /activity_submissions/{submissionId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin() || isProfessor());
      allow create: if isAluno() && isOwner(request.resource.data.studentId);
      allow update: if isAdmin() || isProfessor() || (isAluno() && isOwner(resource.data.studentId));
      allow delete: if isAdmin() || isProfessor();
    }

    match /rubrics/{rubricId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /calendar_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isProfessor();
      allow update, delete: if isAdmin() || (isProfessor() && resource.data.createdBy == request.auth.uid);
    }

    match /forum_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }

    match /evidence_portfolio/{portfolioId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isProfessor() || isAdmin());
      allow create: if isAluno() && isOwner(request.resource.data.studentId);
      allow update, delete: if isAluno() && isOwner(resource.data.studentId) || isAdmin();
    }

    match /class_dashboard_stats/{classId} {
      allow read: if isTeacher() || isAdmin();
      allow write: if isAdmin(); // Should be updated by service/function
    }

    match /aiProviders/{providerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /aiUsageLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /gamification_profiles/{studentId} {
      allow read: if isOwner(studentId) || isAdmin() || isProfessor();
      allow write: if isAdmin() || isProfessor();
    }
    
    match /student_achievements/{achievementId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isProfessor();
      allow write: if isAdmin() || isProfessor();
    }
    
    match /student_points/{pointId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isProfessor();
      allow write: if isAdmin() || isProfessor();
    }
    
    match /simulator_attempts/{attemptId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isProfessor();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) || isAdmin() || isProfessor();
      allow delete: if isAdmin();
    }
    
    match /quiz_attempts/{attemptId} {
      allow read: if isOwner(resource.data.userId) || isAdmin() || isProfessor();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) || isAdmin() || isProfessor();
      allow delete: if isAdmin();
    }
    
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }
    
    match /simulators/{simulatorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }
    
    match /lab_submissions/{submissionId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || isProfessor();
      allow create: if isOwner(request.resource.data.studentId);
      allow update: if isAdmin() || isProfessor() || isOwner(resource.data.studentId);
      allow delete: if isAdmin();
    }

    match /smart_alerts/{alertId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || resource.data.targetUserId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    match /studentRiskScores/{studentId} {
      allow read: if isAuthenticated() && (isAdmin() || isProfessor() || studentId == request.auth.uid);
      allow write: if isAdmin() || isProfessor();
    }

    // Default catch-all (MOVE TO END)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
