rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "djalmabatistajunior@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           getUserData().role == 'admin')
        );
    }

    function isProfessor() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'professor';
    }

    function isAluno() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'aluno';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidQuestion(data) {
      // Validating the new SAEPQuestion structure
      return hasRequiredFields(['enunciado', 'alternativas', 'respostaCorreta', 'dificuldade']) &&
             isValidString('enunciado', 1, 5000) &&
             data.alternativas is list &&
             data.alternativas.size() >= 2 &&
             data.respostaCorreta is string &&
             data.dificuldade in ['fácil', 'médio', 'difícil'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isProfessor();
      allow create: if isOwner(userId) && 
        (request.resource.data.role in ['professor', 'aluno'] || request.auth.token.email == "djalmabatistajunior@gmail.com");
      allow update: if isAdmin() || (isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role));
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if (isAdmin() || isProfessor()) && isValidQuestion(request.resource.data);
      allow update: if (isAdmin() || isProfessor()) && isValidQuestion(request.resource.data);
      allow delete: if isAdmin() || isProfessor();
    }

    match /simulados/{simuladoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /resultados/{resultadoId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || isProfessor();
      allow create: if isOwner(request.resource.data.studentId);
      allow update, delete: if isAdmin();
    }

    match /desempenho/{desempenhoId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || isProfessor();
      allow write: if isAdmin() || isProfessor();
    }

    // Legacy/Other collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || !('userId' in resource.data));
      allow write: if isAdmin() || isProfessor();
    }

    match /diagnostics/{diagnosticId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /student_exams/{studentExamId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Allow students to write their exams
    }

    match /simulado_forms/{formId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }

    match /exam_submissions/{submissionId} {
      allow read: if isOwner(resource.data.studentId) || isAdmin() || isProfessor();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /disciplines/{disciplineId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProfessor();
    }
  }
}
