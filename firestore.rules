rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PILLAR 3: Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // PILLAR 4: Role-based access (Using get() is standard for staff checks)
    function isStaff() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['TEACHER', 'ADMIN', 'COORDINATOR'];
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isStaff();
    }

    // Turmas e Competências (PILLAR 1 & 8)
    match /turmas/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    match /competencias/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Simulados e Resultados
    match /simulados/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    match /resultados_simulado/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // EduJarvis Memory and Learning DNA
    match /JarvisMemory/{id} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isStaff());
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.userId || isStaff());
    }

    match /LearningDNA/{id} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isStaff());
      allow write: if isStaff();
    }
    
    // Learning Materials & AI Analytics
    match /materiais_pedagogicos/{id} {
      allow read, write: if isStaff();
    }
    
    match /analises_edu_jarvis/{id} {
      allow read, write: if isStaff();
    }
    
    // Performance Situations (PBL)
    match /learning_situations/{id} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    // Health Check System
    match /_health/{id} {
      allow read, write: if true; 
    }
  }
}
