rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Collection: classes
    // Collection: disciplines
    // Collection: competencias
    // Collection: habilidades
    // Collection: importacoes
    // Collection: insights_ia
    // Collection: recomendacoes_pedagogicas
    // Collection: alertas_pedagogicos
    // ... (and others)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "djalmabatistajunior@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidDiscipline(data) {
      return hasRequiredFields(['name', 'code', 'status']) &&
             isValidString('name', 1, 100) &&
             isValidString('code', 1, 20) &&
             data.status in ['active', 'inactive'];
    }

    function isValidClass(data) {
      return hasRequiredFields(['name', 'period', 'status']) &&
             isValidString('name', 1, 100) &&
             isValidString('period', 1, 50) &&
             data.status in ['active', 'inactive'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidClass(request.resource.data);
      allow update: if isAdmin() && isValidClass(request.resource.data);
      allow delete: if isAdmin();
    }

    match /disciplines/{disciplineId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidDiscipline(request.resource.data);
      allow update: if isAdmin() && isValidDiscipline(request.resource.data);
      allow delete: if isAdmin();
    }

    match /competencias/{competenciaId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /habilidades/{habilidadeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /importacoes/{importacaoId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    match /insights_ia/{insightId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
    }

    match /recomendacoes_pedagogicas/{recomendacaoId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
    }

    match /alertas_pedagogicos/{alertaId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
    }

    match /intervencoes_pedagogicas/{intervencaoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /bloom_analyses/{analysisId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /socratic_sessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read, write: if isOwner(resource.data.userId);
    }

    match /chat_messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /exam_submissions/{submissionId} {
      allow read, write: if isAuthenticated();
    }

    match /study_plans/{planId} {
      allow read, write: if isAuthenticated();
    }

    match /student_exams/{studentExamId} {
      allow read, write: if isAuthenticated();
    }

    match /diagnostics/{diagnosticId} {
      allow read, write: if isAuthenticated();
    }

    match /learning_profiles/{profileId} {
      allow read, write: if isAuthenticated();
    }

    match /adaptive_sessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    match /cognitive_error_analyses/{analysisId} {
      allow read, write: if isAuthenticated();
    }

    match /recovery_plans/{planId} {
      allow read, write: if isAuthenticated();
    }

    match /lesson_plans/{planId} {
      allow read, write: if isAuthenticated();
    }

    match /performance_predictions/{predictionId} {
      allow read, write: if isAuthenticated();
    }

    match /engagement_logs/{logId} {
      allow read, write: if isAuthenticated();
    }

    match /learning_dna/{dnaId} {
      allow read, write: if isAuthenticated();
    }

    match /content_recommendations/{recId} {
      allow read, write: if isAuthenticated();
    }

    match /smart_goals/{goalId} {
      allow read, write: if isAuthenticated();
    }

    match /educational_missions/{missionId} {
      allow read, write: if isAuthenticated();
    }

    match /career_matches/{matchId} {
      allow read, write: if isAuthenticated();
    }

    match /smart_alerts/{alertId} {
      allow read, write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
        (request.resource.data.role in ['professor', 'aluno'] || request.auth.token.email == "djalmabatistajunior@gmail.com");
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role; // Cannot change role
    }
  }
}
