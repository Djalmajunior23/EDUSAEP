# .env.example
# URL do webhook do n8n para disparo de notificações
N8N_WEBHOOK_URL=
N8N_CHATBOT_WEBHOOK_URL=

# AI Configuration
ENABLE_AI=true
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.0-pro
GEMINI_FALLBACK_MODEL=gemini-2.0-flash-lite

# AI Provider Keys (Hidden in Backend)
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=

# Security
WEBHOOK_SECRET=

# Supabase (Hybrid DB)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxx
