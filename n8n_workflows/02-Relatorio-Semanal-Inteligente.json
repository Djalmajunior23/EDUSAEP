        "httpHeaderAuth": {
          "id": "sua-credencial",
          "name": "Token HTTP Firestore"
        }
      }
    },
    {
      "parameters": {
        "model": "gemini-3.1-pro",
        "prompt": "=Você é um sistema de Inteligência Artificial Analítica da plataforma EduSAEP.\n\nAnalise os seguintes logs do sistema dessa semana e gere um relatório de 3 parágrafos focando em:\n1. Nível de engajamento.\n2. Quantidade de alunos que caíram na régua de risco.\n3. Pontos de sucesso nas intervenções.\n\nJSON de Dados: \n{{ JSON.stringify($json.documents) }}\n"
      },
      "id": "c138af64-160a-4298-b7ab-8f9dafc126b8",
      "name": "Google Gemini (Análise de Dados)",
      "type": "n8n-nodes-base.googleGemini",
      "typeVersion": 1,
      "position": [
        860,
        300
      ],
      "credentials": {
        "googleGeminiApi": {
          "id": "sua-credencial-gemini",
          "name": "EduSAEP Gemini API"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "relatorios@edusaep.com",
        "toEmail": "diretoria@escola.com",
        "subject": "EduSAEP - Relatório de Inteligência Pedagógica Semanal",
        "html": "=Prezada Diretoria,<br><br>Segue abaixo o relatório automático gerado pelo motor de inteligência do EduSAEP referente aos dados coletados na última semana:<br><br><hr><br><strong>{{ $json.text }}</strong><br><hr><br>Qualquer dúvida, verifiquem o Painel Administrativo em <i>Backstage Governance</i> da plataforma.<br><br>Att,<br>Equipe Automática EduSAEP."
      },
