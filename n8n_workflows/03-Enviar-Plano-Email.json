{
  "name": "EduAI Core-Recovery-Email-Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "n8n/plans",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "id": "webhook-trigger",
      "name": "Webhook: EnviarPlanoEmail"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.body.type}}",
              "value2": "EnviarPlanoEmail"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 300],
      "id": "filter-trigger",
      "name": "Filtro: EnviarPlanoEmail"
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "to": "={{$json.body.studentEmail}}",
        "subject": "Seu Plano de Estudos Personalizado - EduAI Core",
        "text": "=Olá {{$json.body.studentName}}, seu plano de estudos foi gerado. \nDetalhes: {{$json.body.plan}}",
        "options": {}
      },
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [700, 300],
      "id": "send-email",
      "name": "Gmail: Enviar Plano"
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "SEU_SHEET_ID_DE_LOGS",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Logs_Atividades",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "ID_Workflow": "EduAI Core-Recovery-Email-Workflow",
            "Tipo_Acao": "Enviar Plano Email",
            "Data_Hora": "={{ new Date().toISOString() }}",
            "Status": "Sucesso",
            "Resultado_IA": "={{ $json.body.studentEmail }}",
            "Tempo_Execucao": "={{ $execution.duration }}"
          },
          "matchingColumns": [],
          "schemaMode": "auto"
        }
      },
      "id": "f5123d45-6789-0abc-def1-23456789abca",
      "name": "Log no Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.1,
      "position": [920, 300]
    }
  ],
  "connections": {
    "webhook-trigger": {
      "main": [
        [
          {
            "node": "filter-trigger",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "filter-trigger": {
      "main": [
        [
          {
            "node": "send-email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "send-email": {
      "main": [
        [
          {
            "node": "Log no Google Sheets",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
