{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The email of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "photoURL": { "type": "string", "description": "The photo URL of the user." },
        "emailVerified": { "type": "boolean", "description": "Whether the user's email is verified." },
        "role": { "type": "string", "enum": ["aluno", "professor", "admin"], "description": "The user's role in the system." },
        "xp": { "type": "number", "description": "The user's experience points." },
        "level": { "type": "number", "description": "The user's current level." },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "List of badge IDs earned by the user." },
        "gamificationEnabled": { "type": "boolean", "description": "Whether gamification is enabled for the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "settings": {
          "type": "object",
          "description": "User account settings.",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark"], "description": "UI theme preference." },
            "notifications": { "type": "boolean", "description": "Whether notifications are enabled." },
            "webhookUrl": { "type": "string", "description": "Webhook URL for N8N integration." }
          }
        },
        "preferences": {
          "type": "object",
          "description": "User pedagogical preferences.",
          "properties": {
            "defaultGrade": { "type": "string", "description": "Default grade level for diagnostics." },
            "language": { "type": "string", "description": "Preferred language for the interface." }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Diagnostic": {
      "title": "Diagnostic Result",
      "description": "Stores the generated diagnostic for a student or group.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who generated this diagnostic." },
        "aluno": { "type": "string", "description": "The name of the student or group." },
        "result": { "type": "object", "description": "The full diagnostic result from Gemini." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the diagnostic was generated." }
      },
      "required": ["userId", "aluno", "result", "createdAt"]
    },
    "Task": {
      "title": "To-do Task",
      "description": "A task in the user's to-do list.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this task." },
        "title": { "type": "string", "description": "The title of the task." },
        "completed": { "type": "boolean", "description": "Whether the task is completed." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the task was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the task was last updated." }
      },
      "required": ["userId", "title", "completed", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the AI chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who sent or received this message." },
        "text": { "type": "string", "description": "The content of the message." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "The role of the message sender." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["userId", "text", "role", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "description": "A question in the question bank.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The question text." },
        "options": { "type": "array", "items": { "type": "string" }, "description": "The answer options." },
        "correctOption": { "type": "integer", "description": "The index of the correct option." },
        "weight": { "type": "number", "description": "The weight of the question." },
        "competency": { "type": "string", "description": "The competency this question belongs to." },
        "skill": { "type": "string", "description": "The specific skill this question tests." },
        "difficulty": { "type": "string", "enum": ["fácil", "médio", "difícil"], "description": "The difficulty level." },
        "createdBy": { "type": "string", "description": "The ID of the user who created this question." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the question was created." }
      },
      "required": ["text", "options", "correctOption", "competency", "difficulty"]
    },
    "Exam": {
      "title": "Exam",
      "description": "A simulated exam.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the exam." },
        "description": { "type": "string", "description": "The description of the exam." },
        "subject": { "type": "string", "description": "The subject of the exam." },
        "questions": { "type": "array", "items": { "$ref": "Question" }, "description": "The list of questions in this exam." },
        "createdBy": { "type": "string", "description": "The ID of the user who created this exam." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the exam was created." },
        "status": { "type": "string", "enum": ["draft", "published"], "description": "The status of the exam." }
      },
      "required": ["title", "subject", "questions", "createdBy"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A student's submission for an exam or exercise.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "The ID of the student." },
        "examId": { "type": "string", "description": "The ID of the exam or exercise." },
        "answers": { "type": "object", "description": "The student's answers (questionIndex -> optionIndex)." },
        "score": { "type": "number", "description": "The total score achieved." },
        "maxScore": { "type": "number", "description": "The maximum possible score." },
        "completedAt": { "type": "string", "format": "date-time", "description": "When the submission was completed." },
        "competencyResults": { "type": "object", "description": "Results broken down by competency." }
      },
      "required": ["studentId", "examId", "answers", "score", "completedAt"]
    },
    "StudyPlan": {
      "title": "Study Plan",
      "description": "A personalized study plan for a student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the student." },
        "strengths": { "type": "array", "items": { "type": "string" }, "description": "Identified strengths." },
        "weaknesses": { "type": "array", "items": { "type": "string" }, "description": "Identified weaknesses." },
        "priorityTopics": { "type": "array", "items": { "type": "object" }, "description": "Topics to prioritize." },
        "recommendedExercises": { "type": "array", "items": { "type": "object" }, "description": "Recommended content and exercises." },
        "recommendations": { "type": "array", "items": { "type": "string" }, "description": "General recommendations." },
        "competencyAnalysis": { "type": "object", "description": "Detailed competency performance data." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the plan was generated." }
      },
      "required": ["userId", "strengths", "weaknesses", "createdAt"]
    },
    "StudentExam": {
      "title": "Student Exam",
      "description": "Relationship between a student and an exam.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "The ID of the student." },
        "examId": { "type": "string", "description": "The ID of the exam." },
        "status": { "type": "string", "enum": ["assigned", "in_progress", "completed"], "description": "The status of the exam for this student." },
        "assignedAt": { "type": "string", "format": "date-time", "description": "When the exam was assigned." }
      },
      "required": ["studentId", "examId", "status"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Stores global application configurations.",
      "type": "object",
      "properties": {
        "webhookUrl": { "type": "string", "description": "Global webhook URL for N8N integration." },
        "updatedBy": { "type": "string", "description": "UID of the user who last updated the settings." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the settings were last updated." }
      }
    },
    "Class": {
      "title": "Class",
      "description": "A class or group of students.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the class." },
        "period": { "type": "string", "description": "Period or semester." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Status." }
      },
      "required": ["name", "period", "status"]
    },
    "Discipline": {
      "title": "Discipline",
      "description": "A discipline or main competency.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the discipline." },
        "description": { "type": "string", "description": "Description of the discipline." },
        "code": { "type": "string", "description": "UC code." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Status." }
      },
      "required": ["name", "code", "status"]
    },
    "Competencia": {
      "title": "Competencia",
      "description": "A competency linked to a discipline.",
      "type": "object",
      "properties": {
        "discipline_id": { "type": "string", "description": "ID of the discipline." },
        "name": { "type": "string", "description": "Name of the competency." },
        "description": { "type": "string", "description": "Description." }
      },
      "required": ["discipline_id", "name"]
    },
    "Habilidade": {
      "title": "Habilidade",
      "description": "A skill linked to a competency.",
      "type": "object",
      "properties": {
        "competencia_id": { "type": "string", "description": "ID of the competency." },
        "name": { "type": "string", "description": "Name of the skill." },
        "description": { "type": "string", "description": "Description." }
      },
      "required": ["competencia_id", "name"]
    },
    "Importacao": {
      "title": "Importacao",
      "description": "Record of data imports.",
      "type": "object",
      "properties": {
        "origem": { "type": "string", "description": "Source of data." },
        "arquivo_nome": { "type": "string", "description": "Filename." },
        "data_importacao": { "type": "string", "format": "date-time", "description": "Date." },
        "status": { "type": "string", "description": "Status." },
        "observacoes": { "type": "string", "description": "Notes." }
      },
      "required": ["origem", "data_importacao", "status"]
    },
    "InsightIA": {
      "title": "InsightIA",
      "description": "Insights generated by AI.",
      "type": "object",
      "properties": {
        "tipo": { "type": "string", "description": "Type of insight." },
        "referencia_id": { "type": "string", "description": "ID of the reference entity." },
        "resumo": { "type": "string", "description": "Summary." },
        "json_resposta": { "type": "object", "description": "Full AI response." },
        "data_geracao": { "type": "string", "format": "date-time", "description": "Date." }
      },
      "required": ["tipo", "resumo", "json_resposta", "data_geracao"]
    },
    "RecomendacaoPedagogica": {
      "title": "RecomendacaoPedagogica",
      "description": "Pedagogical recommendations.",
      "type": "object",
      "properties": {
        "aluno_id": { "type": "string", "description": "Student ID." },
        "turma_id": { "type": "string", "description": "Class ID." },
        "disciplina_id": { "type": "string", "description": "Discipline ID." },
        "competencia_id": { "type": "string", "description": "Competency ID." },
        "tipo_recomendacao": { "type": "string", "description": "Type." },
        "descricao": { "type": "string", "description": "Description." },
        "prioridade": { "type": "string", "description": "Priority." },
        "status": { "type": "string", "description": "Status." },
        "data_geracao": { "type": "string", "format": "date-time", "description": "Date." }
      },
      "required": ["tipo_recomendacao", "descricao", "data_geracao"]
    },
    "AlertaPedagogico": {
      "title": "AlertaPedagogico",
      "description": "Pedagogical alerts.",
      "type": "object",
      "properties": {
        "aluno_id": { "type": "string", "description": "Student ID." },
        "turma_id": { "type": "string", "description": "Class ID." },
        "tipo_alerta": { "type": "string", "description": "Type." },
        "nivel": { "type": "string", "description": "Level." },
        "descricao": { "type": "string", "description": "Description." },
        "data_geracao": { "type": "string", "format": "date-time", "description": "Date." },
        "resolvido": { "type": "boolean", "description": "Resolved status." }
      },
      "required": ["tipo_alerta", "nivel", "descricao", "data_geracao", "resolvido"]
    },
    "IntervencaoPedagogica": {
      "title": "IntervencaoPedagogica",
      "description": "Teacher interventions suggested by AI.",
      "type": "object",
      "properties": {
        "professor_id": { "type": "string", "description": "Professor ID." },
        "turma_id": { "type": "string", "description": "Class ID." },
        "competencia_id": { "type": "string", "description": "Competency ID." },
        "titulo": { "type": "string", "description": "Title of the intervention." },
        "descricao": { "type": "string", "description": "Detailed description." },
        "roteiro_aula": { "type": "string", "description": "Suggested lesson plan." },
        "status": { "type": "string", "enum": ["pendente", "aplicada", "arquivada"], "description": "Status." },
        "data_geracao": { "type": "string", "format": "date-time", "description": "Generation date." }
      },
      "required": ["professor_id", "turma_id", "titulo", "descricao", "data_geracao"]
    },
    "BloomAnalysis": {
      "title": "BloomAnalysis",
      "description": "Analysis of exam balance based on Bloom's Taxonomy.",
      "type": "object",
      "properties": {
        "exam_id": { "type": "string", "description": "Exam ID." },
        "distribution": { "type": "object", "description": "Percentage of questions per Bloom level." },
        "health_score": { "type": "number", "description": "Overall balance score." },
        "recommendations": { "type": "string", "description": "AI recommendations for balance." },
        "data_analise": { "type": "string", "format": "date-time", "description": "Analysis date." }
      },
      "required": ["exam_id", "distribution", "data_analise"]
    },
    "SocraticSession": {
      "title": "SocraticSession",
      "description": "Session for the Socratic AI Tutor.",
      "type": "object",
      "properties": {
        "aluno_id": { "type": "string", "description": "Student ID." },
        "question_id": { "type": "string", "description": "Question being discussed." },
        "status": { "type": "string", "enum": ["ativa", "concluida"], "description": "Session status." },
        "history": { "type": "array", "items": { "$ref": "ChatMessage" }, "description": "Message history." },
        "data_inicio": { "type": "string", "format": "date-time", "description": "Start date." }
      },
      "required": ["aluno_id", "question_id", "status", "data_inicio"]
    },
    "LearningProfile": {
      "title": "Learning Profile",
      "description": "Stores the student's learning style and cognitive profile.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "vark_style": { "type": "string", "enum": ["Visual", "Aural", "Read/Write", "Kinesthetic", "Multimodal"], "description": "VARK learning style." },
        "cognitive_level": { "type": "string", "description": "Cognitive maturity level." },
        "behavioral_traits": { "type": "array", "items": { "type": "string" }, "description": "Identified behavioral traits." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update date." }
      },
      "required": ["userId", "vark_style", "updatedAt"]
    },
    "AdaptiveSession": {
      "title": "Adaptive Session",
      "description": "Tracks an adaptive exam session with dynamic difficulty.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "examId": { "type": "string", "description": "Original exam ID." },
        "currentProficiency": { "type": "number", "description": "Estimated student proficiency (TRI)." },
        "questionHistory": { "type": "array", "items": { "type": "object" }, "description": "History of questions and answers." },
        "status": { "type": "string", "enum": ["active", "completed"], "description": "Session status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Start date." }
      },
      "required": ["userId", "examId", "currentProficiency", "status", "createdAt"]
    },
    "LessonPlan": {
      "title": "Lesson Plan",
      "description": "Stores AI-generated lesson plans based on class cognitive errors.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the professor." },
        "title": { "type": "string", "description": "The title of the lesson plan." },
        "objectives": { "type": "array", "items": { "type": "string" }, "description": "Learning objectives." },
        "topicsToReview": { "type": "array", "items": { "type": "string" }, "description": "Topics that need review." },
        "practicalActivities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Name of the activity." },
              "description": { "type": "string", "description": "Description of the activity." },
              "duration": { "type": "string", "description": "Estimated duration." }
            }
          },
          "description": "Practical activities for the lesson."
        },
        "suggestedMaterials": { "type": "array", "items": { "type": "string" }, "description": "Suggested materials." },
        "aiInsights": { "type": "string", "description": "AI insights and reasoning." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the plan was created." }
      },
      "required": ["userId", "title", "objectives", "createdAt"]
    },
    "RecoveryPlan": {
      "title": "Recovery Plan",
      "description": "Stores individualized recovery plans for students based on cognitive error analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the student this plan is for." },
        "studentId": { "type": "string", "description": "The ID of the student." },
        "riskLevel": { "type": "string", "enum": ["Baixo", "Médio", "Alto"], "description": "The risk level of the student." },
        "summary": { "type": "string", "description": "A summary of the diagnostic." },
        "recommendedActivities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "competency": { "type": "string", "description": "The competency to focus on." },
              "activityType": { "type": "string", "description": "The type of activity." },
              "description": { "type": "string", "description": "Description of the activity." }
            }
          },
          "description": "List of recommended activities."
        },
        "professorInterventions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Suggested interventions for the professor."
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the plan was created." }
      },
      "required": ["userId", "studentId", "riskLevel", "summary", "createdAt"]
    },
    "CognitiveErrorAnalysis": {
      "title": "Cognitive Error Analysis",
      "description": "Analysis of student errors by cognitive category.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "submissionId": { "type": "string", "description": "Submission ID." },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "category": { "type": "string", "enum": ["Interpretação", "Conceito", "Atenção", "Lógica"] },
              "explanation": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date of analysis." }
      },
      "required": ["userId", "submissionId", "errors", "createdAt"]
    },
    "PerformancePrediction": {
      "title": "Performance Prediction",
      "description": "AI-generated prediction of student performance in official exams.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "probabilityOfSuccess": { "type": "number", "description": "Probability (0-100)." },
        "riskLevel": { "type": "string", "enum": ["Baixo", "Médio", "Alto", "Crítico"] },
        "factors": { "type": "array", "items": { "type": "string" }, "description": "Factors influencing the prediction." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date of prediction." }
      },
      "required": ["userId", "probabilityOfSuccess", "riskLevel", "createdAt"]
    },
    "EngagementLog": {
      "title": "Engagement Log",
      "description": "Logs student engagement metrics.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "action": { "type": "string", "description": "Action performed (e.g., 'login', 'start_exam')." },
        "duration": { "type": "number", "description": "Duration in seconds (if applicable)." },
        "sentiment": { "type": "string", "description": "Detected sentiment (if applicable)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred." }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "LearningDNA": {
      "title": "Learning DNA",
      "description": "Dynamic multidimensional profile of the student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "learningStyle": { "type": "string", "enum": ["Visual", "Auditivo", "Leitura/Escrita", "Cinestésico"] },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "averagePace": { "type": "string", "description": "Average learning pace (e.g., 'Rápido', 'Moderado')." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "learningStyle", "updatedAt"]
    },
    "ContentRecommendation": {
      "title": "Content Recommendation",
      "description": "AI-curated external content for the student.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "title": { "type": "string", "description": "Title of the content." },
        "url": { "type": "string", "description": "Link to the external content." },
        "type": { "type": "string", "enum": ["Vídeo", "Artigo", "Exercício"] },
        "reason": { "type": "string", "description": "Why this was recommended." },
        "competency": { "type": "string", "description": "Target competency." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "url", "type", "reason", "createdAt"]
    },
    "SmartGoal": {
      "title": "Smart Goal",
      "description": "Negotiated weekly micro-goals.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "title": { "type": "string", "description": "Goal title." },
        "description": { "type": "string", "description": "Goal description." },
        "status": { "type": "string", "enum": ["Pendente", "Em Progresso", "Concluída", "Falhou"] },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "status", "deadline", "createdAt"]
    },
    "EducationalMission": {
      "title": "Educational Mission",
      "description": "Gamified learning missions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Student ID." },
        "title": { "type": "string", "description": "Mission title." },
        "description": { "type": "string", "description": "Mission narrative." },
